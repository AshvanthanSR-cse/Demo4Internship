# AWS Region where your DynamoDB table and S3 bucket are created
AWS_REGION=us-east-1

# AWS Credentials (only needed if not using an IAM role / AWS CLI profile)
# AWS_ACCESS_KEY_ID=your_access_key_here
# AWS_SECRET_ACCESS_KEY=your_secret_key_here

# S3 bucket used to store user files
S3_BUCKET=cloudvault-storage

# DynamoDB table used to store user records
DYNAMODB_TABLE=Users

# Port the Express server will listen on
PORT=5000
